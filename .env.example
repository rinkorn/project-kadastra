# Copy to .env and fill in real values. Never commit .env.

# S3-compatible storage
S3_ENDPOINT_URL=https://s3.ohnice.synology.me
S3_BUCKET=kadastrova
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path

# MLflow (used when MLFLOW_ENABLED=true). URL below is what docker-compose.mlflow.yml exposes.
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=kadastra-valuation
MLFLOW_DB_PASSWORD=change-me-in-local-env
